local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ScalingBuffer = require(ReplicatedStorage.RosaRbxPipeline.utils["scaling-buffer"])

return function()
	describe("ScalingBuffer", function()

		describe("new()", function()
			it("starts with size 0", function()
				local buf = ScalingBuffer.new()
				expect(buf:size()).to.equal(0)
			end)
		end)

		describe("push_string()", function()
			it("increases size by the string length", function()
				local buf = ScalingBuffer.new()
				buf:push_string("hello")
				expect(buf:size()).to.equal(5)
			end)

			it("accumulates size across multiple pushes", function()
				local buf = ScalingBuffer.new()
				buf:push_string("abc")
				buf:push_string("de")
				expect(buf:size()).to.equal(5)
			end)

			it("stores the correct string data", function()
				local buf = ScalingBuffer.new()
				buf:push_string("hello world")
				local result = buf:getBuffer()
				expect(buffer.readstring(result, 0, buffer.len(result))).to.equal("hello world")
			end)

			it("concatenates multiple strings correctly", function()
				local buf = ScalingBuffer.new()
				buf:push_string("foo")
				buf:push_string("bar")
				local result = buf:getBuffer()
				expect(buffer.readstring(result, 0, buffer.len(result))).to.equal("foobar")
			end)

			it("handles an empty string push", function()
				local buf = ScalingBuffer.new()
				buf:push_string("")
				expect(buf:size()).to.equal(0)
			end)

			it("triggers auto-resize when data exceeds initial allocation", function()
				local buf   = ScalingBuffer.new()
				local chunk = string.rep("x", 10_000)
				for _ = 1, 12 do
					buf:push_string(chunk)
				end
				expect(buf:size()).to.equal(120_000)
				local result = buf:getBuffer()
				expect(buffer.len(result)).to.equal(120_000)
			end)
		end)

		describe("push_u8()", function()
			it("writes a single byte and advances size by 1", function()
				local buf = ScalingBuffer.new()
				buf:push_u8(42)
				expect(buf:size()).to.equal(1)
				local result = buf:getBuffer()
				expect(buffer.readu8(result, 0)).to.equal(42)
			end)

			it("writes max u8 value (255)", function()
				local buf = ScalingBuffer.new()
				buf:push_u8(255)
				local result = buf:getBuffer()
				expect(buffer.readu8(result, 0)).to.equal(255)
			end)
		end)

		describe("push_u16()", function()
			it("writes two bytes and advances size by 2", function()
				local buf = ScalingBuffer.new()
				buf:push_u16(1000)
				expect(buf:size()).to.equal(2)
				local result = buf:getBuffer()
				expect(buffer.readu16(result, 0)).to.equal(1000)
			end)
		end)

		describe("push_u32()", function()
			it("writes four bytes and advances size by 4", function()
				local buf = ScalingBuffer.new()
				buf:push_u32(100000)
				expect(buf:size()).to.equal(4)
				local result = buf:getBuffer()
				expect(buffer.readu32(result, 0)).to.equal(100000)
			end)
		end)

		describe("getBuffer()", function()
			it("returns a buffer whose length matches size()", function()
				local buf = ScalingBuffer.new()
				buf:push_string("test")
				local result = buf:getBuffer()
				expect(buffer.len(result)).to.equal(buf:size())
			end)

			it("returns a copy — mutating it does not affect the original", function()
				local buf = ScalingBuffer.new()
				buf:push_string("abc")
				local result = buf:getBuffer()
				buffer.writeu8(result, 0, 0xFF)
				local result2 = buf:getBuffer()
				expect(buffer.readu8(result2, 0)).to.equal(string.byte("a"))
			end)
		end)

	end)
end
